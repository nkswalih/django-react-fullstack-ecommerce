DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=core.settings.development
SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost,backend
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
TIME_ZONE=Asia/Kolkata
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PORT=8000
DB_WAIT_TIMEOUT=60
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
DJANGO_COLLECTSTATIC=0
DJANGO_BOOTSTRAP_DATA=1
BOOTSTRAP_FIXTURE_PATH=/app/sqlite_data.json
SQLITE_IMPORT_PATH=/app/db.sqlite3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
